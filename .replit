run = "npm run dev"
entrypoint = "src/App.jsx"
modules = ["nodejs-20"]

hidden = [".config", "package-lock.json"]

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"

[deployment]
build = ["sh", "-c", "npm install && npm run build"]
run = ["sh", "-c", "npm run preview"]
deploymentTarget = "static"
publicDir = "dist"

[[ports]]
localPort = 5173
externalPort = 80
